{
  "mcpServers": {
    "metatrader": {
      "command": "metatrader-mcp-server",
      "args": [
        "--login", "YOUR_MT5_LOGIN",
        "--password", "YOUR_MT5_PASSWORD",
        "--server", "YOUR_MT5_SERVER",
        "--transport", "stdio"
      ],
      "disabled": true,
      "autoApprove": []
    },
    "tradingview": {
      "command": "uvx",
      "args": ["mcp-tradingview-server"],
      "disabled": true,
      "autoApprove": []
    }
  }
}
